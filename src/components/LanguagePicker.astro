---
import { languages, type Lang } from '@/i18n/translations';
import { getLangFromUrl, switchLang } from '@/i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const otherLang: Lang = currentLang === 'zh' ? 'en' : 'zh';
const switchUrl = switchLang(Astro.url, otherLang);
---

<a
  href={switchUrl}
  class="flex items-center gap-1 px-2 py-1 rounded-lg text-sm font-medium transition-colors hover:bg-bg-subtle text-body"
  aria-label={`Switch to ${languages[otherLang]}`}
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
    />
  </svg>
  {languages[otherLang]}
</a>
