---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getAllCategories, getPostsByCategory } from '@/utils/posts';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

const lang: Lang = 'zh';

export async function getStaticPaths() {
  const categories = await getAllCategories('zh');
  return [...categories.keys()].map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const posts = await getPostsByCategory(lang, category!);
---

<BaseLayout title={`${t(lang, 'category.postsIn')} "${category}" | ${t(lang, 'site.title')}`} description={`${t(lang, 'category.postsIn')} ${category}`}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-heading">
        {category}
      </h1>
      <p class="text-muted mt-1">
        {posts.length} {t(lang, 'category.postsIn')}
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
