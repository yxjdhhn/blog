---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

const lang: Lang = 'zh';
---

<BaseLayout title={`${t(lang, 'about.title')} | ${t(lang, 'site.title')}`} description={t(lang, 'site.description')}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-heading mb-8">
      {t(lang, 'about.title')}
    </h1>

    <div class="prose">
      <p>
        你好！欢迎来到我的个人博客。
      </p>

      <p>
        我是一名热爱技术的开发者，在这个博客上，我会分享我在软件开发、技术探索和日常思考中的收获和见解。
      </p>
      

      <h2>联系我</h2>

      <p>
        如果你有任何问题或想法，欢迎通过以下方式联系我：
      </p>

      <ul>
        <li>GitHub: <a href="https://github.com/yxjdhhn" target="_blank" rel="noopener noreferrer">@yxjdhhn</a></li>
        <li>Email: yyykit2635@163.com</li>
      </ul>
    </div>
  </section>
</BaseLayout>
