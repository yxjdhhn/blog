---
import { getLangFromUrl, t } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<div class="relative" id="search-container">
  <button
    id="search-btn"
    type="button"
    class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm text-muted bg-bg-subtle hover:bg-bg-subtle-hover transition-colors"
    aria-label={t(lang, 'nav.search')}
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="hidden sm:inline">{t(lang, 'nav.search')}</span>
    <kbd class="hidden sm:inline-flex items-center gap-0.5 px-1.5 py-0.5 text-xs font-mono bg-bg-subtle-hover rounded">
      <span class="text-xs">⌘</span>K
    </kbd>
  </button>
</div>

<!-- Search Modal -->
<div id="search-modal" class="hidden fixed inset-0 z-[100]">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="search-overlay"></div>
  <div class="relative max-w-2xl mx-auto mt-[15vh] px-4">
    <div class="bg-bg-card rounded-xl shadow-2xl border border-border-strong overflow-hidden">
      <div id="pagefind-search" data-lang={lang}></div>
    </div>
  </div>
</div>

<link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />

<script is:inline>
  (function() {
    var initialized = false;

    function setupSearch() {
      var btn = document.getElementById('search-btn');
      var modal = document.getElementById('search-modal');
      var overlay = document.getElementById('search-overlay');
      var searchDiv = document.getElementById('pagefind-search');

      if (!btn || !modal || !overlay || !searchDiv) return;

      function openModal() {
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';

        if (!initialized) {
          initialized = true;
          import('/_pagefind/pagefind-ui.js').then(function(module) {
            new module.PagefindUI({
              element: '#pagefind-search',
              showSubResults: true,
              showImages: false,
            });
            setTimeout(function() {
              var input = searchDiv.querySelector('input');
              if (input) input.focus();
            }, 100);
          }).catch(function() {
            searchDiv.innerHTML = '<p style="padding:1rem;text-align:center;color:#888;">Search is available after building the site (npm run build).</p>';
          });
        } else {
          setTimeout(function() {
            var input = searchDiv.querySelector('input');
            if (input) input.focus();
          }, 100);
        }
      }

      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }

      btn.addEventListener('click', openModal);
      overlay.addEventListener('click', closeModal);

      document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (modal.classList.contains('hidden')) {
            openModal();
          } else {
            closeModal();
          }
        }
        if (e.key === 'Escape') closeModal();
      });
    }

    setupSearch();
    document.addEventListener('astro:after-swap', setupSearch);
  })();
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-heading);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Inter', -apple-system, sans-serif;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-size: 1rem;
    padding: 0.75rem 1rem;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: var(--pagefind-ui-primary);
  }
</style>
