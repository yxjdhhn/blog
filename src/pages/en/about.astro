---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

const lang: Lang = 'en';
---

<BaseLayout title={`${t(lang, 'about.title')} | ${t(lang, 'site.title')}`} description={t(lang, 'site.description')}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-3xl font-bold text-heading mb-8">
      {t(lang, 'about.title')}
    </h1>

    <div class="prose">
      <p>
        Hello! Welcome to my personal blog.
      </p>

      <p>
        I'm a developer passionate about technology. On this blog, I share my insights and experiences
        in software development, technical exploration, and daily reflections.
      </p>

      <h2>Contact</h2>

      <p>
        If you have any questions or ideas, feel free to reach out:
      </p>

      <ul>
        <li>GitHub: <a href="https://github.com/yxjdhhn" target="blank">@yxjdhhn</a></li>
        <li>Email: yyykit2635@163.com</li>
      </ul>
    </div>
  </section>
</BaseLayout>
