---
import ThemeToggle from './ThemeToggle.astro';
import LanguagePicker from './LanguagePicker.astro';
import Search from './Search.astro';
import { getLangFromUrl, t, getLocalizedUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const navItems = [
  { label: t(lang, 'nav.home'), href: getLocalizedUrl(lang, '/') },
  { label: t(lang, 'nav.tags'), href: getLocalizedUrl(lang, '/tags/') },
  { label: t(lang, 'nav.about'), href: getLocalizedUrl(lang, '/about') },
];

function isActive(href: string): boolean {
  if (href.endsWith('/') && href.length > 4) {
    return currentPath.startsWith(href);
  }
  return currentPath === href || currentPath === href + '/';
}
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={getLocalizedUrl(lang, '/')}
        class="text-xl font-bold text-heading hover:text-primary transition-colors"
      >
        {t(lang, 'site.title')}
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {navItems.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(href)
                ? 'text-primary bg-primary-bg'
                : 'text-secondary hover:text-heading hover:bg-bg-subtle',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Right side controls -->
      <div class="flex items-center gap-1">
        <Search />
        <LanguagePicker />
        <ThemeToggle />

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden p-2 rounded-lg text-secondary hover:bg-bg-subtle"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4">
      {navItems.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
            isActive(href)
              ? 'text-primary bg-primary-bg'
              : 'text-secondary hover:text-heading hover:bg-bg-subtle',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open');
    const closeIcon = document.getElementById('menu-close');
    if (!btn || !menu || !openIcon || !closeIcon) return;

    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }

  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
